# FuelStation OS — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. The same URL is used by Prisma Client and
# Prisma Migrate. If you use a connection pooler (e.g. PgBouncer, Supabase),
# set DATABASE_URL to the pooler URL and uncomment DIRECT_URL below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fuelstation_dev
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/fuelstation_dev

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32-output

# Base URL of the application (no trailing slash).
# Required for Auth.js to construct callback URLs correctly.
AUTH_URL=http://localhost:3000

# ── Node environment ─────────────────────────────────────────────────────────
# Must be "development" for the seed script to run (it guards against
# seeding demo passwords in production — see prisma/seed.ts).
NODE_ENV=development

# ── Upstash Redis (rate limiting) ────────────────────────────────────────────
# Required in production and staging environments.
# In development (NODE_ENV=development), the rate limiter falls back to an
# in-memory store so no Redis instance is needed locally.
#
# Setup:
#   1. Create a free Upstash account at https://upstash.com
#   2. Create a Redis database (Global or Regional)
#   3. Copy the REST URL and REST token from the database console
#
# WARNING: If these are missing in production, the login rate limiter will
# throw a RateLimitConfigError and block all login attempts (fail closed).
# This is intentional — do not remove them in staging/production deployments.
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_rest_token_here
