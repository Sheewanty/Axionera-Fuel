// Prisma schema for FuelStation OS
// Every operational table is scoped by tenant_id and station_id

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl is used by Prisma Migrate when DATABASE_URL points to a pooler
  // directUrl = env("DIRECT_URL")
}

// ─── Tenancy ──────────────────────────────────────────────────────────────────

model Tenant {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  subscriptionStatus  String   @default("TRIAL") // TRIAL | ACTIVE | SUSPENDED | CANCELLED
  subscriptionPackage String   @default("STARTER")
  maxStations         Int      @default(1)
  maxTanks            Int      @default(3)
  maxPumps            Int      @default(3)
  billingEmail        String?
  billingAddress      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  stations    Station[]
  memberships Membership[]
  products    Product[]
  creditors   Creditor[]
  stockAdjustments StockAdjustment[]
}

model Station {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String
  location  String?
  status    String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  // Note: Membership.stationId references this ID but has no Prisma FK relation
  // (sentinel "" used for tenant-wide memberships — see Membership model comments)
  pumps               Pump[]
  nozzles             Nozzle[]
  tanks               Tank[]
  dailySessions       DailySession[]
  pumpReadings        PumpReading[]
  tankDippings        TankDipping[]
  discharges          ProductDischarge[]
  stockAdjustments    StockAdjustment[]
  cashCollections     CashCollection[]
  paymentDetails      PaymentDetail[]
  creditors           Creditor[]
  creditorLedger      CreditorLedgerEntry[]
  expenditures        Expenditure[]
  martSales           MartSale[]
  lubeBaySales        LubeBaySale[]
  lubeBayServiceTypes LubeBayServiceType[]
  lubeBayMomoOperators LubeBayMomoOperator[]
  auditLogs           AuditLog[]

  @@unique([tenantId, code])
}

// ─── Users & Roles ────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String?
  avatarInitials String?
  status         String   @default("ACTIVE") // ACTIVE | INACTIVE
  isSuperAdmin   Boolean  @default(false)
  forcePasswordChange Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships Membership[]
  accounts    Account[]
  sessions    Session[]
}

model Membership {
  id        String   @id @default(cuid())
  tenantId  String
  //
  // stationId stores the station cuid for station-scoped roles, or "" (empty string)
  // for tenant-wide roles (OWNER, ADMIN, ACCOUNTANT, AUDITOR).
  //
  // WHY NOT NULLABLE: In Postgres, @@unique([tenantId, userId, stationId]) does NOT
  // prevent duplicate NULLs — NULL != NULL. Making the column non-nullable with a
  // sentinel makes the unique index reliable.
  //
  // WHY NO FK RELATION TO STATION: Prisma cannot express a conditional FK
  // (only when stationId != ""). The application layer must validate that
  // stationId is either "" or a valid Station.id belonging to the same tenant.
  // This is enforced in M2 service methods and seeded correctly by upsertMembership().
  //
  stationId String   @default("")
  userId    String
  role      String // OWNER | ADMIN | STATION_MANAGER | SUPERVISOR | ATTENDANT | ACCOUNTANT | AUDITOR
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId, stationId])
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Products & Prices ────────────────────────────────────────────────────────

model Product {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  category  String   @default("FUEL") // FUEL | LUBRICANT | OTHER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id])
  priceHistory     PriceHistory[]
  nozzles          Nozzle[]
  tanks            Tank[]
  pumpReadings     PumpReading[]
  tankDippings     TankDipping[]
  discharges       ProductDischarge[]
  stockAdjustments StockAdjustment[]
  paymentDetails   PaymentDetail[]
  creditorLedger   CreditorLedgerEntry[]
  lubeBaySales     LubeBaySale[]
  lubeBaySaleLines LubeBaySaleLine[]
}

model PriceHistory {
  id            String    @id @default(cuid())
  tenantId      String
  stationId     String
  productId     String
  pricePerLitre Decimal   @db.Decimal(10, 4)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdBy     String
  createdAt     DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])
}

// ─── Station Setup ────────────────────────────────────────────────────────────

model Pump {
  id        String   @id @default(cuid())
  tenantId  String
  stationId String
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  station Station  @relation(fields: [stationId], references: [id])
  nozzles Nozzle[]
}

model Nozzle {
  id        String   @id @default(cuid())
  tenantId  String
  stationId String
  pumpId    String
  productId String
  name      String
  meterCode String?
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  station      Station       @relation(fields: [stationId], references: [id])
  pump         Pump          @relation(fields: [pumpId], references: [id])
  product      Product       @relation(fields: [productId], references: [id])
  pumpReadings PumpReading[]
}

model Tank {
  id             String   @id @default(cuid())
  tenantId       String
  stationId      String
  productId      String
  name           String
  capacityLitres Decimal  @db.Decimal(10, 2)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  station           Station            @relation(fields: [stationId], references: [id])
  product           Product            @relation(fields: [productId], references: [id])
  tankDippings      TankDipping[]
  productDischarges ProductDischarge[]
  stockAdjustments  StockAdjustment[]
}

// ─── Daily Operations ─────────────────────────────────────────────────────────

model DailySession {
  id              String    @id @default(cuid())
  tenantId        String
  stationId       String
  businessDate    DateTime  @db.Date
  shift           String    @default("DAY") // DAY | NIGHT
  status          String    @default("OPEN") // OPEN | READY_FOR_REVIEW | APPROVED | REOPENED
  openedBy        String
  closedBy        String?
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  supervisorNotes String?

  station             Station               @relation(fields: [stationId], references: [id])
  pumpReadings        PumpReading[]
  tankDippings        TankDipping[]
  cashCollections     CashCollection[]
  paymentDetails      PaymentDetail[]
  expenditures        Expenditure[]
  martSales           MartSale[]
  productDischarges   ProductDischarge[]
  stockAdjustments    StockAdjustment[]
  creditorLedger      CreditorLedgerEntry[]
  lubeBaySales        LubeBaySale[]

  @@unique([tenantId, stationId, businessDate, shift])
}

model PumpReading {
  id                String   @id @default(cuid())
  tenantId          String
  stationId         String
  dailySessionId    String
  businessDate      DateTime @db.Date
  shift             String
  pumpId            String
  nozzleId          String
  productId         String
  attendantId       String?
  previousLitre     Decimal  @db.Decimal(12, 2)
  currentLitre      Decimal  @db.Decimal(12, 2)
  litresSold        Decimal  @db.Decimal(12, 2) // server computed
  pricePerLitre     Decimal  @db.Decimal(10, 4)
  amountExpected    Decimal  @db.Decimal(12, 2) // server computed
  cashReceived      Decimal  @db.Decimal(12, 2)
  gocardAmount      Decimal  @default(0) @db.Decimal(12, 2) // HQ settlement
  couponAmount      Decimal  @default(0) @db.Decimal(12, 2) // HQ settlement
  ghqrAmount        Decimal  @default(0) @db.Decimal(12, 2) // HQ settlement
  creditorsAmount   Decimal  @default(0) @db.Decimal(12, 2) // credit sales, tracked in controlled creditor ledger
  variance          Decimal  @db.Decimal(12, 2) // server computed: totalCollected - amountExpected
  isClosingRecorded Boolean  @default(true)
  remarks           String?
  createdBy         String
  updatedBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  station      Station      @relation(fields: [stationId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])
  nozzle       Nozzle       @relation(fields: [nozzleId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@unique([tenantId, dailySessionId, nozzleId])
}

model TankDipping {
  id                 String   @id @default(cuid())
  tenantId           String
  stationId          String
  dailySessionId     String
  businessDate       DateTime @db.Date
  tankId             String
  productId          String
  openingStockLitres Decimal  @db.Decimal(12, 2)
  receiptsLitres     Decimal  @default(0) @db.Decimal(12, 2)
  closingDipCm       Decimal? @db.Decimal(8, 2)
  closingStockLitres Decimal  @db.Decimal(12, 2)
  meterSoldLitres    Decimal  @db.Decimal(12, 2) // server computed
  varianceLitres     Decimal  @db.Decimal(12, 2) // server computed
  waterTestStatus    String   @default("CLEAR") // CLEAR | WATER_DETECTED
  supervisorId       String?
  remarks            String?
  createdBy          String
  updatedBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  station      Station      @relation(fields: [stationId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])
  tank         Tank         @relation(fields: [tankId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@unique([tenantId, dailySessionId, tankId])
}

model ProductDischarge {
  id                           String   @id @default(cuid())
  tenantId                     String
  stationId                    String
  dailySessionId               String
  businessDate                 DateTime @db.Date
  tankId                       String
  productId                    String
  supplierName                 String
  invoiceNumber                String
  sealNumbers                  String?
  sealNumbersContinued         String?
  compartmentNumber            String?
  invoiceMeasurement           Decimal  @db.Decimal(12, 2)
  stationMeasurement           Decimal? @db.Decimal(12, 2)
  productDischargedLitres      Decimal  @db.Decimal(12, 2)
  vehicleRegistrationNumber    String?
  stationSupervisorName        String?
  couplingHeightCm             Decimal? @db.Decimal(8, 2)
  calibrationCertificate       String?
  tbar                         Decimal? @db.Decimal(8, 2)
  tankerWaterTestStatus        String   @default("CLEAR") // CLEAR | WATER_DETECTED | NOT_TESTED
  receivingTankWaterTestStatus String   @default("CLEAR") // CLEAR | WATER_DETECTED | NOT_TESTED
  waterTestRemarks             String?
  topUpLitres                  Decimal  @default(0) @db.Decimal(12, 2)
  beforeTankLitres             Decimal  @db.Decimal(12, 2)
  expectedTankAfterDischarge   Decimal  @db.Decimal(12, 2) // server computed
  afterTankLitres              Decimal  @db.Decimal(12, 2)
  dischargeVarianceLitres      Decimal  @db.Decimal(12, 2) // server computed
  driverName                   String?
  dealerName                   String?
  remarks                      String?
  createdBy                    String
  updatedBy                    String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  station      Station      @relation(fields: [stationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])
  tank         Tank         @relation(fields: [tankId], references: [id])

  @@index([tenantId, dailySessionId])
  @@index([tenantId, dailySessionId, tankId])
}

model StockAdjustment {
  id              String   @id @default(cuid())
  tenantId        String
  stationId       String
  dailySessionId  String
  businessDate    DateTime @db.Date
  tankId          String
  productId       String
  adjustmentType  String   // REGULATORY_INSPECTION | STOCK_CORRECTION | EVAPORATION | OTHER
  direction       String   // IN | OUT
  litres          Decimal  @db.Decimal(12, 2)
  authorityReason String?
  reference       String?
  recordedByName  String?
  approvedByName  String?
  approvalStatus  String   @default("APPROVED") // PENDING | APPROVED | REJECTED
  remarks         String?
  createdBy       String
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  station      Station      @relation(fields: [stationId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])
  tank         Tank         @relation(fields: [tankId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@index([tenantId, dailySessionId])
  @@index([tenantId, dailySessionId, tankId])
  @@index([tenantId, stationId, businessDate])
}

model PaymentDetail {
  id              String   @id @default(cuid())
  tenantId        String
  stationId       String
  dailySessionId  String
  businessDate    DateTime @db.Date
  productId       String?
  pumpReadingId   String?
  channel         String // GO_CARD | VISA | GOIL_COUPON | YY_COUPON | GHQR
  amount          Decimal  @db.Decimal(12, 2)
  customerName    String?
  attendantName   String?
  referenceNumber String?
  serialNumber    String?
  phoneNumber     String?
  status          String   @default("PENDING") // PENDING | SUBMITTED_TO_HQ | SETTLED | CANCELLED
  remarks         String?
  createdBy       String
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  station      Station      @relation(fields: [stationId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])

  @@index([tenantId, dailySessionId])
  @@index([tenantId, stationId, businessDate])
  @@index([tenantId, channel, status])
}

model Creditor {
  id          String   @id @default(cuid())
  tenantId    String
  stationId   String
  name        String
  phone       String?
  email       String?
  creditLimit Decimal? @db.Decimal(12, 2)
  openingBalance Decimal @default(0) @db.Decimal(12, 2)
  status      String   @default("ACTIVE") // ACTIVE | INACTIVE
  notes       String?
  createdBy   String
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  station       Station               @relation(fields: [stationId], references: [id])
  ledgerEntries CreditorLedgerEntry[]
  lubeBaySales  LubeBaySale[]

  @@unique([tenantId, stationId, name])
  @@index([tenantId, stationId, status])
}

model CreditorLedgerEntry {
  id                 String    @id @default(cuid())
  tenantId           String
  stationId          String
  dailySessionId     String
  creditorId         String
  businessDate       DateTime  @db.Date
  type               String // SALE | PAYMENT
  amount             Decimal   @db.Decimal(12, 2)
  productId          String?
  pumpReadingId      String?
  lubeBaySaleId      String?
  paymentMethod      String? // CASH | CHEQUE | CARD | MOMO
  chequeNumber       String?
  chequeName         String?
  chequeBank         String?
  chequeBranch       String?
  chequeClearingDate DateTime? @db.Date
  cashReceivedDate   DateTime? @db.Date
  cardDetails        String?
  momoOperator       String?
  momoNumber         String?
  referenceNumber    String?
  remarks            String?
  createdBy          String
  updatedBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  station      Station      @relation(fields: [stationId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])
  creditor     Creditor     @relation(fields: [creditorId], references: [id])
  product      Product?     @relation(fields: [productId], references: [id])
  lubeBaySale  LubeBaySale? @relation(fields: [lubeBaySaleId], references: [id])

  @@index([tenantId, stationId, dailySessionId])
  @@index([tenantId, creditorId, businessDate])
  @@index([tenantId, type, paymentMethod])
}

model CashCollection {
  id                      String    @id @default(cuid())
  tenantId                String
  stationId               String
  dailySessionId          String
  businessDate            DateTime  @db.Date
  amountToBank            Decimal   @db.Decimal(12, 2)
  bankCollectionDate      DateTime? @db.Date
  bankCollectionReference String?
  expectedCash            Decimal   @db.Decimal(12, 2) // server computed
  variance                Decimal   @db.Decimal(12, 2) // server computed
  bankSignatureName       String?
  supervisorSignatureName String?
  remarks                 String?
  createdBy               String
  updatedBy               String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  station      Station      @relation(fields: [stationId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])
}

model Expenditure {
  id               String   @id @default(cuid())
  tenantId         String
  stationId        String
  dailySessionId   String?
  businessDate     DateTime @db.Date
  voucherReference String?
  category         String
  amount           Decimal  @db.Decimal(12, 2)
  paymentToBank    Decimal  @default(0) @db.Decimal(12, 2) // reduces net expenditure
  paidBy           String
  approvedBy       String?
  receiptAttached  Boolean  @default(false)
  description      String?
  createdBy        String
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  station      Station       @relation(fields: [stationId], references: [id])
  dailySession DailySession? @relation(fields: [dailySessionId], references: [id])
}

model MartSale {
  id             String   @id @default(cuid())
  tenantId       String
  stationId      String
  dailySessionId String
  businessDate   DateTime @db.Date
  openingCash    Decimal  @default(0) @db.Decimal(12, 2)
  posSales       Decimal  @default(0) @db.Decimal(12, 2)
  cashSales      Decimal  @default(0) @db.Decimal(12, 2)
  mobileMoney    Decimal  @default(0) @db.Decimal(12, 2)
  returns        Decimal  @default(0) @db.Decimal(12, 2)
  netMartSales   Decimal  @db.Decimal(12, 2) // server computed
  cashCount      Decimal  @default(0) @db.Decimal(12, 2)
  variance       Decimal  @db.Decimal(12, 2) // server computed
  remarks        String?
  createdBy      String
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  station      Station      @relation(fields: [stationId], references: [id])
  dailySession DailySession @relation(fields: [dailySessionId], references: [id])

  @@unique([tenantId, dailySessionId])
}

model LubeBaySale {
  id                 String   @id @default(cuid())
  tenantId           String
  stationId          String
  dailySessionId     String
  businessDate       DateTime @db.Date
  vehicleReg         String
  customerName       String?
  customerPhone      String?
  serviceTypeId      String?
  serviceType        String
  vehicleCategory    String?
  lubricantProductId String?
  quantity           Decimal  @default(0) @db.Decimal(12, 2)
  unitPrice          Decimal  @default(0) @db.Decimal(12, 2)
  lubricantAmount    Decimal  @db.Decimal(12, 2)
  labourCharge       Decimal  @default(0) @db.Decimal(12, 2)
  partsCharge        Decimal  @default(0) @db.Decimal(12, 2)
  discount           Decimal  @default(0) @db.Decimal(12, 2)
  totalExpected      Decimal  @db.Decimal(12, 2)
  cashAmount         Decimal  @default(0) @db.Decimal(12, 2)
  cardAmount         Decimal  @default(0) @db.Decimal(12, 2)
  momoAmount         Decimal  @default(0) @db.Decimal(12, 2)
  creditorAmount     Decimal  @default(0) @db.Decimal(12, 2)
  creditorId         String?
  paymentMode        String   @default("CASH") // CASH | MOMO | CARD | CREDIT
  momoOperator       String?
  momoNumber         String?
  cardDetails        String?
  variance           Decimal  @db.Decimal(12, 2)
  technicianName     String?
  supervisorName     String?
  remarks            String?
  createdBy          String
  updatedBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  station          Station               @relation(fields: [stationId], references: [id])
  dailySession     DailySession          @relation(fields: [dailySessionId], references: [id])
  lubricantProduct Product?              @relation(fields: [lubricantProductId], references: [id])
  creditor         Creditor?             @relation(fields: [creditorId], references: [id])
  serviceTypeSetup LubeBayServiceType?   @relation(fields: [serviceTypeId], references: [id])
  lines            LubeBaySaleLine[]
  creditorLedger   CreditorLedgerEntry[]

  @@index([tenantId, stationId, businessDate])
  @@index([tenantId, dailySessionId])
  @@index([tenantId, vehicleReg])
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model LubeBaySaleLine {
  id        String   @id @default(cuid())
  tenantId  String
  saleId    String
  productId String
  quantity  Decimal  @db.Decimal(12, 2)
  unitPrice Decimal  @db.Decimal(12, 2)
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale    LubeBaySale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id])

  @@index([tenantId, saleId])
  @@index([tenantId, productId])
}

model LubeBayServiceType {
  id                  String   @id @default(cuid())
  tenantId            String
  stationId           String?
  name                String
  vehicleCategory     String
  defaultLabourCharge Decimal  @default(0) @db.Decimal(12, 2)
  isActive            Boolean  @default(true)
  createdBy           String
  updatedBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  station        Station?      @relation(fields: [stationId], references: [id])
  sales          LubeBaySale[]

  @@unique([tenantId, stationId, name, vehicleCategory])
  @@index([tenantId, stationId, isActive])
}

model LubeBayMomoOperator {
  id        String   @id @default(cuid())
  tenantId  String
  stationId String?
  name      String
  isActive  Boolean  @default(true)
  createdBy String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  station Station? @relation(fields: [stationId], references: [id])

  @@unique([tenantId, stationId, name])
  @@index([tenantId, stationId, isActive])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  stationId   String?
  actorUserId String
  entityType  String
  entityId    String
  action      String // CREATE | UPDATE | DELETE | APPROVE | REOPEN
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())

  station Station? @relation(fields: [stationId], references: [id])

  // Query patterns:
  //   audit trail by tenant, newest-first
  //   entity history: all events on a specific record
  //   actor history: what did this user do?
  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([actorUserId])
}

model ReportRun {
  id             String   @id @default(cuid())
  tenantId       String
  stationId      String?
  templateKey    String
  title          String
  audience       String
  periodFrom     DateTime @db.Date
  periodTo       DateTime @db.Date
  status         String   @default("GENERATING") // GENERATING | COMPLETED | FAILED
  formats        Json
  factsJson      Json
  narrativeJson  Json?
  model          String?
  usedOpenAi     Boolean  @default(false)
  error          String?
  generatedBy    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  artifacts ReportArtifact[]
  sources   ReportSource[]

  @@index([tenantId, createdAt])
  @@index([tenantId, templateKey])
  @@index([tenantId, stationId, periodFrom, periodTo])
}

model ReportArtifact {
  id          String   @id @default(cuid())
  tenantId    String
  reportRunId String
  format      String // PDF | PPTX
  filePath    String
  fileSize    Int
  checksum    String
  createdAt   DateTime @default(now())

  reportRun ReportRun @relation(fields: [reportRunId], references: [id], onDelete: Cascade)

  @@unique([reportRunId, format])
  @@index([tenantId, createdAt])
}

model ReportSource {
  id             String   @id @default(cuid())
  tenantId       String
  reportRunId    String
  sourceType     String
  sourceId       String?
  sourceLabel    String?
  sourceSnapshot Json?
  createdAt      DateTime @default(now())

  reportRun ReportRun @relation(fields: [reportRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, reportRunId])
  @@index([tenantId, sourceType])
}
