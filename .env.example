APP_DOMAIN=example.com
APP_IMAGE=ghcr.io/sheewanty/fuelstation-os:latest
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql://fuelstation:replace-with-strong-postgres-password@postgres:5432/fuelstation_os
AUTH_SECRET=replace-with-openssl-rand-base64-32-output
AUTH_URL=https://example.com
AUTH_TRUST_HOST=true
NODE_ENV=production
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token
